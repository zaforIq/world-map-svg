{
  "name": "world-map-svg",
  "version": "0.4.0",
  "description": "Interactive SVG world map React component",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "svg",
    "world-map",
    "map",
    "interactive-map"
  ],
  "type": "module",
  "main": "./dist/world-map-svg.cjs.js",
  "module": "./dist/world-map-svg.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/world-map-svg.es.js",
      "require": "./dist/world-map-svg.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaforIq/world-map-svg.git"
  },
  "bugs": {
    "url": "https://github.com/zaforIq/world-map-svg/issues"
  },
  "homepage": "https://github.com/zaforIq/world-map-svg#readme",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
